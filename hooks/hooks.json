{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/user_prompt_submit_arc.py\"",
            "statusMessage": "Classifying ARC task risk",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$|^apply_patch$|^Edit$|^Write$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/post_tool_use_arc.py\"",
            "statusMessage": "Recording ARC tool result",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/stop_arc.py\"",
            "statusMessage": "Writing ARC telemetry",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
